# Copy to .env and fill values. Never commit real secrets.
DATABASE_URL="file:./dev.db"
AUTH_SECRET="change-me-to-a-long-random-string"

# Delivery: mock | live
DELIVERY_MODE="mock"
# WHATSAPP_API_TOKEN=
# SMTP_HOST=

# SEFAZ DistDFe: auto (live se houver A1) | mock | live
SEFAZ_MODE="auto"
# NFS-e ADN (opcional para live)
# NFSE_ADN_BASE_URL="https://sefin.nfse.gov.br/sefinnacional"

# Pagamento de guias: mock | live
PAYMENT_MODE="mock"

# E-mail: mock | live (SMTP)
DELIVERY_MODE="mock"
# SMTP_HOST=
