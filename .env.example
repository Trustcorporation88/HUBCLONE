# Obrigatório — sem mock. Preencha todos os valores reais.

# Postgres (Railway: use a variável DATABASE_URL do plugin PostgreSQL)
# Ex.: postgresql://user:pass@host:5432/railway
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/railway"

AUTH_SECRET="cole-um-segredo-longo-e-aleatorio"

# E-mail real (SMTP)
SMTP_HOST="smtp.seuprovedor.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="guias@seuescritorio.com.br"

# NFS-e Sistema Nacional (ADN) — captura live
NFSE_ADN_BASE_URL="https://sefin.nfse.gov.br/sefinnacional"

# Inbox IA (também pode salvar a chave em Integrações → OpenAI)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1"

# ProContador SaaS (www.procontador.com.br) — API base opcional
# Default: https://api.procontador.com.br/api/v1
# Credenciais (e-mail/senha admin) ficam em Integrações → ProContador
PROCONTADOR_API_URL="https://api.procontador.com.br/api/v1"

# Nunca ligue em produção
ALLOW_DEMO="false"
