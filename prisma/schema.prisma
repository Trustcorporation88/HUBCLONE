generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Escritório de contabilidade (tenant)
model Firm {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  clients     Client[]
  processes   ProcessTemplate[]
  tasks       Task[]
  obligations Obligation[]
  xmlDocs     XmlDocument[]
  pipelines   FiscalPipeline[]
}

model User {
  id        String   @id @default(cuid())
  firmId    String
  email     String
  name      String
  role      String   @default("STAFF") // OWNER | MANAGER | STAFF | CLIENT
  createdAt DateTime @default(now())

  firm         Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  assignedTasks Task[] @relation("TaskAssignee")

  @@unique([firmId, email])
}

/// Cliente do escritório (empresa atendida)
model Client {
  id           String   @id @default(cuid())
  firmId       String
  legalName    String
  tradeName    String?
  cnpj         String
  regime       String   @default("SIMPLES") // SIMPLES | LUCRO_PRESUMIDO | LUCRO_REAL | MEI
  whatsapp     String?
  email        String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  firm         Firm             @relation(fields: [firmId], references: [id], onDelete: Cascade)
  tasks        Task[]
  obligations  Obligation[]
  xmlDocs      XmlDocument[]
  pipelines    FiscalPipeline[]

  @@unique([firmId, cnpj])
  @@index([firmId])
}

/// Template de processo recorrente (inspirado Karbon + TaskHub)
model ProcessTemplate {
  id          String   @id @default(cuid())
  firmId      String
  name        String
  code        String
  department  String   // FISCAL | CONTABIL | DP | SOCIETARIO | ATENDIMENTO
  regimeScope String   @default("ALL") // ALL | SIMPLES | ...
  recurring   Boolean  @default(true)
  dayOfMonth  Int?     // dia típico de vencimento
  stepsJson   String   @default("[]") // JSON array of step definitions
  createdAt   DateTime @default(now())

  firm  Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@unique([firmId, code])
}

model Task {
  id          String    @id @default(cuid())
  firmId      String
  clientId    String?
  templateId  String?
  assigneeId  String?
  title       String
  description String?
  status      String    @default("PENDING") // PENDING | IN_PROGRESS | BLOCKED | DONE | CANCELLED
  priority    String    @default("NORMAL") // LOW | NORMAL | HIGH | URGENT
  department  String    @default("FISCAL")
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  firm       Firm             @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client     Client?          @relation(fields: [clientId], references: [id])
  template   ProcessTemplate? @relation(fields: [templateId], references: [id])
  assignee   User?            @relation("TaskAssignee", fields: [assigneeId], references: [id])
  obligation Obligation?
  pipeline   FiscalPipeline?

  @@index([firmId, status])
  @@index([firmId, dueAt])
}

/// Guia / obrigação fiscal (MonitorHub+)
model Obligation {
  id            String    @id @default(cuid())
  firmId        String
  clientId      String
  taskId        String?   @unique
  type          String    // DAS | DARF | GPS | DCTFWEB | PGDAS | CND | FGTS | ISS | GNRE | OTHER
  competence    String    // YYYY-MM
  amountCents   Int?
  barcode       String?
  status        String    @default("DRAFT") // DRAFT | READY | SENT | VIEWED | PAID | OVERDUE | CANCELLED
  dueAt         DateTime?
  sentAt        DateTime?
  viewedAt      DateTime?
  paidAt        DateTime?
  proofUrl      String?
  sourcePortal  String?   // e-CAC | FGTS | SEFAZ | MANUAL
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  task   Task?  @relation(fields: [taskId], references: [id])

  @@index([firmId, status])
  @@index([clientId, competence])
}

/// XML fiscal compra/venda (XMLHub + Qive-level model)
model XmlDocument {
  id            String   @id @default(cuid())
  firmId        String
  clientId      String
  accessKey     String
  docType       String   // NFE | NFCE | NFSE | CTE | CFE | MDFE
  direction     String   // IN | OUT
  issuerCnpj    String?
  recipientCnpj String?
  issuedAt      DateTime?
  amountCents   Int?
  status        String   @default("CAPTURED") // CAPTURED | AUDITED | OK | WARNING | ERROR | IMPORTED
  auditJson     String?  // JSON audit findings
  rawPath       String?
  createdAt     DateTime @default(now())

  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([firmId, accessKey])
  @@index([clientId, direction])
}

/// Moat: captura → audita → apura → guia → paga → prova → fecha tarefa
model FiscalPipeline {
  id           String   @id @default(cuid())
  firmId       String
  clientId     String
  taskId       String?  @unique
  obligationType String @default("DAS")
  competence   String
  stage        String   @default("CAPTURE") // CAPTURE | AUDIT | APURATE | GUIDE | PAY | PROVE | CLOSE
  stageStatus  String   @default("PENDING") // PENDING | RUNNING | DONE | FAILED | NEEDS_APPROVAL
  metaJson     String   @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  task   Task?  @relation(fields: [taskId], references: [id])

  @@index([firmId, stage])
  @@unique([firmId, clientId, obligationType, competence])
}
