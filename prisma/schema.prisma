generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Escritório de contabilidade (tenant)
model Firm {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  brandName    String?
  brandTagline String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users        User[]
  clients      Client[]
  processes    ProcessTemplate[]
  tasks        Task[]
  obligations  Obligation[]
  xmlDocs      XmlDocument[]
  pipelines    FiscalPipeline[]
  deliveries   Delivery[]
  certificates Certificate[]
  captureRuns  CaptureRun[]
  payments     Payment[]
  timeEntries  TimeEntry[]
  slaPolicies  SlaPolicy[]
  xmlFindings  XmlAuditFinding[]
  integrations Integration[]
  contracts    Contract[]
  inboxItems   InboxItem[]
  fiscalAlerts FiscalAlert[]
}

model User {
  id           String   @id @default(cuid())
  firmId       String
  clientId     String?
  email        String
  name         String
  passwordHash String   @default("")
  role         String   @default("STAFF") // OWNER | MANAGER | STAFF | CLIENT
  createdAt    DateTime @default(now())

  firm          Firm    @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client        Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  assignedTasks Task[]  @relation("TaskAssignee")
  timeEntries   TimeEntry[]

  @@unique([firmId, email])
  @@index([clientId])
}

/// Cliente do escritório (empresa atendida)
model Client {
  id           String   @id @default(cuid())
  firmId       String
  legalName    String
  tradeName    String?
  cnpj         String
  regime       String   @default("SIMPLES") // SIMPLES | LUCRO_PRESUMIDO | LUCRO_REAL | MEI
  whatsapp     String?
  email        String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  firm         Firm             @relation(fields: [firmId], references: [id], onDelete: Cascade)
  users        User[]
  tasks        Task[]
  obligations  Obligation[]
  xmlDocs      XmlDocument[]
  pipelines    FiscalPipeline[]
  certificates Certificate[]
  captureRuns  CaptureRun[]
  timeEntries  TimeEntry[]
  contracts    Contract[]
  inboxItems   InboxItem[]
  fiscalAlerts FiscalAlert[]

  @@unique([firmId, cnpj])
  @@index([firmId])
}

/// Template de processo recorrente (inspirado Karbon + TaskHub)
model ProcessTemplate {
  id          String   @id @default(cuid())
  firmId      String
  name        String
  code        String
  department  String   // FISCAL | CONTABIL | DP | SOCIETARIO | ATENDIMENTO
  regimeScope String   @default("ALL") // ALL | SIMPLES | ...
  recurring   Boolean  @default(true)
  dayOfMonth  Int?     // dia típico de vencimento
  stepsJson   String   @default("[]") // JSON array of step definitions
  createdAt   DateTime @default(now())

  firm  Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@unique([firmId, code])
}

model Task {
  id          String    @id @default(cuid())
  firmId      String
  clientId    String?
  templateId  String?
  assigneeId  String?
  title       String
  description String?
  status      String    @default("PENDING") // PENDING | IN_PROGRESS | BLOCKED | DONE | CANCELLED
  priority    String    @default("NORMAL") // LOW | NORMAL | HIGH | URGENT
  department  String    @default("FISCAL")
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  firm        Firm             @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client      Client?          @relation(fields: [clientId], references: [id])
  template    ProcessTemplate? @relation(fields: [templateId], references: [id])
  assignee    User?            @relation("TaskAssignee", fields: [assigneeId], references: [id])
  obligation  Obligation?
  pipeline    FiscalPipeline?
  timeEntries TimeEntry[]

  @@index([firmId, status])
  @@index([firmId, dueAt])
  @@index([firmId, department])
}

/// Guia / obrigação fiscal (MonitorHub+)
model Obligation {
  id            String    @id @default(cuid())
  firmId        String
  clientId      String
  taskId        String?   @unique
  type          String    // DAS | DARF | GPS | DCTFWEB | PGDAS | CND | FGTS | ISS | GNRE | OTHER
  competence    String    // YYYY-MM
  amountCents   Int?
  barcode       String?
  pixPayload    String?
  status        String    @default("DRAFT") // DRAFT | READY | SENT | VIEWED | PAID | OVERDUE | CANCELLED
  dueAt         DateTime?
  sentAt        DateTime?
  viewedAt      DateTime?
  paidAt        DateTime?
  proofUrl      String?
  sourcePortal  String?   // e-CAC | FGTS | SEFAZ | MANUAL
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  task   Task?  @relation(fields: [taskId], references: [id])
  deliveries Delivery[]
  payments   Payment[]

  @@index([firmId, status])
  @@index([clientId, competence])
}

/// Envio de guia (ConnectHub / Confi): e-mail + WhatsApp com rastreio
model Delivery {
  id            String    @id @default(cuid())
  firmId        String
  obligationId  String
  channel       String    // EMAIL | WHATSAPP
  toAddress     String
  status        String    @default("QUEUED") // QUEUED | SENT | DELIVERED | VIEWED | FAILED
  providerMsgId String?
  bodyPreview   String?
  errorMessage  String?
  sentAt        DateTime?
  viewedAt      DateTime?
  createdAt     DateTime  @default(now())

  firm       Firm       @relation(fields: [firmId], references: [id], onDelete: Cascade)
  obligation Obligation @relation(fields: [obligationId], references: [id], onDelete: Cascade)

  @@index([obligationId])
  @@index([firmId, status])
}

/// Pagamento de guia (Dootax / Pag Útil level)
model Payment {
  id            String    @id @default(cuid())
  firmId        String
  obligationId  String
  method        String    // PIX | BOLETO
  status        String    @default("PENDING") // PENDING | PAID | EXPIRED | FAILED | CANCELLED
  amountCents   Int
  pixCopyPaste  String?
  boletoBarcode String?
  boletoDigitable String?
  providerRef   String?
  proofPath     String?
  paidAt        DateTime?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  firm       Firm       @relation(fields: [firmId], references: [id], onDelete: Cascade)
  obligation Obligation @relation(fields: [obligationId], references: [id], onDelete: Cascade)

  @@index([obligationId])
  @@index([firmId, status])
}

/// XML fiscal compra/venda (XMLHub + Qive-level model)
model XmlDocument {
  id            String   @id @default(cuid())
  firmId        String
  clientId      String
  accessKey     String
  docType       String   // NFE | NFCE | NFSE | CTE | CFE | MDFE
  direction     String   // IN | OUT
  issuerCnpj    String?
  recipientCnpj String?
  issuedAt      DateTime?
  amountCents   Int?
  status        String   @default("CAPTURED") // CAPTURED | AUDITED | OK | WARNING | ERROR | IMPORTED
  auditJson     String?  // JSON audit findings
  rawPath       String?
  nsu           String?
  schemaSource  String?  // SEFAZ_DISTDFE | MOCK | UPLOAD
  createdAt     DateTime @default(now())

  firm     Firm              @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client   Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  findings XmlAuditFinding[]

  @@unique([firmId, accessKey])
  @@index([clientId, direction])
}

/// Moat: captura → audita → apura → guia → paga → prova → fecha tarefa
model FiscalPipeline {
  id           String   @id @default(cuid())
  firmId       String
  clientId     String
  taskId       String?  @unique
  obligationType String @default("DAS")
  competence   String
  stage        String   @default("CAPTURE") // CAPTURE | AUDIT | APURATE | GUIDE | PAY | PROVE | CLOSE
  stageStatus  String   @default("PENDING") // PENDING | RUNNING | DONE | FAILED | NEEDS_APPROVAL
  metaJson     String   @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  task   Task?  @relation(fields: [taskId], references: [id])

  @@index([firmId, stage])
  @@unique([firmId, clientId, obligationType, competence])
}

/// Certificado A1 (.pfx) do cliente — mTLS DistDFe
model Certificate {
  id               String    @id @default(cuid())
  firmId           String
  clientId         String?
  cnpj             String
  label            String
  pfxPath          String
  passwordEnc      String
  environment      String    @default("2") // 1=prod 2=homolog
  lastNsu          String    @default("000000000000000")
  lastNsuCte       String    @default("000000000000000")
  lastNsuNfse      String    @default("000000000000000")
  validFrom        DateTime?
  validTo          DateTime?
  subjectCn        String?
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  firm        Firm         @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  captureRuns CaptureRun[]

  @@index([firmId, cnpj])
}

model CaptureRun {
  id            String    @id @default(cuid())
  firmId        String
  clientId      String
  certificateId String?
  mode          String    // MOCK | LIVE
  kindsJson     String    @default("[\"NFE\"]")
  status        String    @default("RUNNING") // RUNNING | DONE | FAILED
  docsFound     Int       @default(0)
  docsSaved     Int       @default(0)
  ultNsu        String?
  maxNsu        String?
  cStat         String?
  xMotivo       String?
  errorMessage  String?
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?

  firm        Firm         @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  certificate Certificate? @relation(fields: [certificateId], references: [id], onDelete: SetNull)

  @@index([firmId, startedAt])
}

/// Horas lançadas — P&L interno por cliente
model TimeEntry {
  id              String   @id @default(cuid())
  firmId          String
  clientId        String
  userId          String
  taskId          String?
  minutes         Int
  hourlyRateCents Int      @default(0)
  costRateCents   Int      @default(0)
  billable        Boolean  @default(true)
  note            String?
  workedAt        DateTime @default(now())
  createdAt       DateTime @default(now())

  firm   Firm  @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task   Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([firmId, clientId])
  @@index([firmId, workedAt])
}

/// SLA de resposta/envio por canal
model SlaPolicy {
  id          String   @id @default(cuid())
  firmId      String
  channel     String   // EMAIL | WHATSAPP
  department  String   @default("ALL")
  targetHours Int      @default(24)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@unique([firmId, channel, department])
}

/// Achados de auditoria XML (bloqueiam fechamento se blocking)
model XmlAuditFinding {
  id            String   @id @default(cuid())
  firmId        String
  xmlDocumentId String
  severity      String   // INFO | WARNING | ERROR
  code          String
  message       String
  blocking      Boolean  @default(false)
  createdAt     DateTime @default(now())

  firm        Firm        @relation(fields: [firmId], references: [id], onDelete: Cascade)
  xmlDocument XmlDocument @relation(fields: [xmlDocumentId], references: [id], onDelete: Cascade)

  @@index([firmId, blocking])
  @@index([xmlDocumentId])
}

/// Marketplace de integrações (credenciais criptografadas)
model Integration {
  id             String    @id @default(cuid())
  firmId         String
  provider       String    // DOMINIO | OMIE | CLICKSIGN | OPENAI
  status         String    @default("DISCONNECTED") // DISCONNECTED | CONNECTED | ERROR
  credentialsEnc String?
  metaJson       String    @default("{}")
  lastSyncAt     DateTime?
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@unique([firmId, provider])
}

/// Contrato / OS — assinatura por upload de PDF assinado
model Contract {
  id             String    @id @default(cuid())
  firmId         String
  clientId       String
  title          String
  kind           String    @default("OS") // CONTRACT | OS
  status         String    @default("DRAFT") // DRAFT | SENT | SIGNED | REJECTED
  originalPath   String?
  signedPdfPath  String?
  notes          String?
  sentAt         DateTime?
  signedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([firmId, status])
  @@index([clientId])
}

/// Inbox inteligente — classificação OpenAI
model InboxItem {
  id             String    @id @default(cuid())
  firmId         String
  clientId       String
  uploadedById   String?
  filename       String
  mimeType       String
  filePath       String
  classification String?   // DAS | NFE | CONTRACT | PROOF | OTHER
  confidence     Float?
  rawAiJson      String?
  status         String    @default("PENDING") // PENDING | CLASSIFIED | TRIAGED | REJECTED
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([firmId, status])
  @@index([clientId])
}

/// Saúde fiscal — alertas derivados de dados reais
model FiscalAlert {
  id         String    @id @default(cuid())
  firmId     String
  clientId   String
  type       String    // CERT_EXPIRING | CND_MISSING | OVERDUE | XML_ERROR
  severity   String    @default("WARNING") // INFO | WARNING | CRITICAL
  message    String
  metaJson   String    @default("{}")
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([firmId, resolvedAt])
  @@index([clientId, type])
}
